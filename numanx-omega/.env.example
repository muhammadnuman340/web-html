# Copy to .env.local for local dev (never commit .env.local)
# In Netlify: Site settings → Environment variables → Add each (scopes: Builds)

# Paddle checkout (optional — Pro upgrade; uses sandbox test defaults if unset)
VITE_PADDLE_TOKEN=test_your_paddle_client_token
VITE_PADDLE_PRICE_ID=pri_your_price_id
VITE_PADDLE_ENV=sandbox
# Leave empty to use current site URL + /?payment=success (recommended on Netlify)
VITE_PADDLE_SUCCESS_URL=
