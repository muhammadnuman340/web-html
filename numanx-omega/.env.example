# Copy to .env for local dev (never commit .env with real keys to git)
# In Netlify: Site settings → Environment variables → Add each (scopes: Builds)

# ─────────────────────────────────────────────────
# Paddle Checkout — REQUIRED for monetization
# ─────────────────────────────────────────────────
# Sign up at https://vendors.paddle.com
# Create a product → get Client-Side Token and Price ID

# Sandbox test card: 4242 4242 4242 4242
# Live: Replace with your real Paddle credentials

VITE_PADDLE_TOKEN=test_your_paddle_client_token
VITE_PADDLE_PRICE_ID=pri_your_price_id

# Set to 'live' when ready to charge real money
VITE_PADDLE_ENV=sandbox

# Leave empty to auto-detect (defaults to current origin + /?payment=success)
VITE_PADDLE_SUCCESS_URL=
